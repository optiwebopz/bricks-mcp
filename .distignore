# WordPress.org SVN deployment exclusions
# Used by 10up/action-wordpress-plugin-deploy

# Version control
.git
.gitignore

# GitHub-specific
.github/

# Planning and internal tooling
.planning/
.claude/

# Development environment
.wp-env.json
node_modules/
.env
.env.local

# Build/test tooling config
.editorconfig
phpcs.xml
phpunit.xml
composer.json
package.json
package-lock.json

# Tests and coverage
tests/
coverage/

# Documentation (not needed in plugin zip)
# readme.txt is intentionally NOT excluded (required by WordPress.org)
README.md
CLAUDE.md
CHANGELOG.md
docs/

# WordPress.org assets dir (deployed to SVN assets/ separately by the action)
.wordpress-org/

# This file itself
.distignore

# Update server (separate Cloudflare Worker, not part of the plugin)
update-server/

# vendor/ is intentionally NOT excluded:
# opis/json-schema is a runtime dependency bundled via Composer
