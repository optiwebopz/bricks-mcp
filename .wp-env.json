{
	"$schema": "https://schemas.wp.org/trunk/wp-env.json",
	"core": "WordPress/WordPress#6.7",
	"phpVersion": "8.2",
	"plugins": ["."],
	"config": {
		"WP_DEBUG": true,
		"WP_DEBUG_LOG": true,
		"WP_DEBUG_DISPLAY": true,
		"SCRIPT_DEBUG": true,
		"WP_ENVIRONMENT_TYPE": "local"
	},
	"mappings": {
		"wp-content/debug.log": "./logs/debug.log"
	},
	"lifecycleScripts": {
		"afterStart": "npx wp-env run cli wp plugin activate bricks-mcp"
	}
}
